# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
# Monorepo com dois projetos Next.js (frontend/ e api/): os padrões abaixo não
# têm barra inicial de propósito, para valerem em qualquer subpasta.

# dependencies
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage

# next.js
.next/
out/

# production
build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# arquivos de mídia originais (não comprimidos, não servidos pelo Next.js)
frontend/raw-media

# typescript
*.tsbuildinfo
next-env.d.ts

# supabase cli
supabase/.temp/
