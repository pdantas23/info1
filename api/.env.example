# Supabase (service role only — esta API nunca lida com sessão de usuário)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Meta Ads (Conversions API)
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# CORS: origens do frontend autorizadas a chamar esta API (separadas por vírgula)
CORS_ALLOWED_ORIGINS=https://saludperfectahoy.com

PORT=3001
