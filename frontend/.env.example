# Supabase (o frontend usa tanto o client de sessão do dashboard quanto o
# admin, já que as Server Actions do dashboard falam direto com o Supabase)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Meta Ads (só o Pixel ID, público — o token da Conversions API vive na api/)
NEXT_PUBLIC_META_PIXEL_ID=4436423349935559

# VTurb Analytics API (server-only, usado no dashboard/Resumo)
VTURB_ANALYTICS_API_TOKEN=

# API separada (checkout, leads, stripe webhook, meta-events)
NEXT_PUBLIC_API_URL=https://api.saludperfectahoy.com

# Geral
NEXT_PUBLIC_SITE_URL=https://saludperfectahoy.com
